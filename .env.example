# LLM API — set LLM_PROVIDER to one of: deepseek, qwen, openai
# Only fill in the API key matching your chosen provider.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=

# Embedding: Phase 1 uses Chroma's built-in onnxruntime MiniLM embedding
# (no config needed). This will change when bge-m3/API embedding is added.

# Vector store: path is currently hardcoded to data/vector_store in the
# scripts (scripts/build_index.py, scripts/query.py, scripts/ask.py,
# frontend/streamlit_app.py), not read from env yet.
